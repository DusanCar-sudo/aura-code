# ============================================================
# Aura Code — API Keys Configuration
# ============================================================
#
# Copy this file to ~/.secrets/agents.env and fill in your keys.
#
#   cp ~/.secrets/agents.env.example ~/.secrets/agents.env
#
# You only need ONE key to get started.
# Aura will automatically detect which providers are configured.
#
# Recommended for beginners: DeepSeek — fast, cheap, generous free tier.
# Get your key at: https://platform.deepseek.com
# ============================================================


# ── DeepSeek ─────────────────────────────────────────────────
# Fast, cheap, excellent at code. Best value for most users.
# Free credits on signup. https://platform.deepseek.com
#
# DEEPSEEK_API_KEY=sk-your-key-here


# ── Zhipu GLM (recommended for long context) ─────────────────
# GLM-5.2 has 1M token context window. Great for large codebases.
# https://open.bigmodel.cn
#
# ZHIPU_API_KEY=your-key-here


# ── Anthropic Claude ─────────────────────────────────────────
# Claude 3.5 Sonnet / Claude 4. Strong reasoning, safe outputs.
# https://console.anthropic.com
#
# ANTHROPIC_API_KEY=sk-ant-your-key-here


# ── OpenAI ───────────────────────────────────────────────────
# GPT-4o, GPT-4o-mini, o1, o3.
# https://platform.openai.com
#
# OPENAI_API_KEY=sk-your-key-here


# ── Google Gemini ─────────────────────────────────────────────
# Gemini 2.0 Flash (free tier available), Gemini 2.5 Pro.
# https://aistudio.google.com/apikey
#
# GEMINI_API_KEY=your-key-here


# ── Groq ─────────────────────────────────────────────────────
# Extremely fast inference. Llama 3.3 70B, Qwen 3, Mixtral.
# Free tier available. https://console.groq.com
#
# GROQ_API_KEY=gsk_your-key-here


# ── OpenRouter ───────────────────────────────────────────────
# Access 200+ models via one key. Claude, GPT, Llama, Mistral, and more.
# Pay per use, no minimums. https://openrouter.ai/keys
#
# OPENROUTER_API_KEY=sk-or-your-key-here


# ── Mistral AI ───────────────────────────────────────────────
# Mistral Large, Codestral (code-specialized), Mistral Nemo.
# https://console.mistral.ai
#
# MISTRAL_API_KEY=your-key-here


# ── Together AI ──────────────────────────────────────────────
# Open source models: Llama, Qwen, DeepSeek, Mixtral.
# https://api.together.ai
#
# TOGETHER_API_KEY=your-key-here


# ── Fireworks AI ─────────────────────────────────────────────
# Fast open-source inference. Llama, Qwen, Mixtral, FireFunction.
# https://fireworks.ai
#
# FIREWORKS_API_KEY=fw_your-key-here


# ── Perplexity ───────────────────────────────────────────────
# Models with real-time web search built in.
# https://www.perplexity.ai/settings/api
#
# PERPLEXITY_API_KEY=pplx-your-key-here


# ── Cohere ───────────────────────────────────────────────────
# Command R+, strong at RAG and tool use.
# https://dashboard.cohere.com
#
# COHERE_API_KEY=your-key-here


# ── xAI Grok ─────────────────────────────────────────────────
# Grok 2, Grok Vision. Large context window.
# https://console.x.ai
#
# XAI_API_KEY=xai-your-key-here


# ── Hugging Face ─────────────────────────────────────────────
# Access thousands of open-source models via Inference API.
# https://huggingface.co/settings/tokens
#
# HUGGINGFACE_API_KEY=hf_your-key-here


# ── Replicate ────────────────────────────────────────────────
# Run open-source models in the cloud. Pay per second.
# https://replicate.com/account/api-tokens
#
# REPLICATE_API_KEY=r8_your-key-here


# ── AI21 Labs ────────────────────────────────────────────────
# Jamba models, strong at long documents.
# https://studio.ai21.com/account/api-key
#
# AI21_API_KEY=your-key-here


# ── Nvidia NIM ───────────────────────────────────────────────
# Enterprise-grade inference, GPU-optimized models.
# https://build.nvidia.com
#
# NVIDIA_API_KEY=nvapi-your-key-here


# ── Cerebras ─────────────────────────────────────────────────
# Extremely fast inference on wafer-scale chips.
# Llama 3.3 70B at 2000+ tokens/sec.
# https://cloud.cerebras.ai
#
# CEREBRAS_API_KEY=csk-your-key-here


# ── SambaNova ────────────────────────────────────────────────
# Fast inference, free tier. Llama, DeepSeek, Qwen.
# https://cloud.sambanova.ai
#
# SAMBANOVA_API_KEY=your-key-here


# ── Ollama (local models — no key needed) ────────────────────
# Run models locally. Completely free, fully private.
# Install: https://ollama.com
# Then pull a model: ollama pull granite4.1:3b
#
# No key required. Just set the base URL if not using localhost:
# OLLAMA_BASE_URL=http://localhost:11434/v1


# ── Telegram Bot (for Aura notifications) ────────────────────
# Optional. Get a bot token from @BotFather on Telegram.
# https://t.me/BotFather
#
# TELEGRAM_BOT_TOKEN=your-bot-token-here
# TELEGRAM_CHAT_ID=your-chat-id-here


# ── GitHub (for repo operations) ─────────────────────────────
# Personal access token with repo scope.
# https://github.com/settings/tokens
#
# GITHUB_TOKEN=ghp_your-token-here


# ============================================================
# How to use this file:
#
# 1. Copy it:
#    cp ~/.secrets/agents.env.example ~/.secrets/agents.env
#
# 2. Edit it:
#    nano ~/.secrets/agents.env
#
# 3. Uncomment the lines for providers you want to use
#    (remove the # at the start of the line)
#
# 4. Replace "your-key-here" with your actual API key
#
# 5. Start Aura:
#    aura
#
# Aura loads this file automatically on startup.
# Never commit ~/.secrets/agents.env to git — it contains real keys.
# This example file (agents.env.example) is safe to commit and share.
# ============================================================
